@import "tailwindcss";

:root {
  --color-background: #0a0d14;
  --color-background-soft: #101522;
  --color-ink: #06080e;
  --color-gold: #d4a843;
  --color-gold-deep: #8b7335;
  --color-cream: #e8e8e8;
  --font-sans: var(--font-body);
  --font-display: var(--font-display);
}

@theme inline {
  --color-background: var(--color-background);
  --color-background-soft: var(--color-background-soft);
  --color-foreground: var(--color-cream);
  --font-sans: var(--font-body);
  --font-display: var(--font-display);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body), sans-serif;
  background:
    radial-gradient(circle at top left, rgba(212, 168, 67, 0.08), transparent 26%),
    linear-gradient(180deg, #0a0d14 0%, #080a11 100%);
}

.site-grid {
  pointer-events: none;
  position: fixed;
  inset: 0;
  z-index: 0;
  opacity: 0.14;
  background-image:
    linear-gradient(rgba(212, 168, 67, 0.12) 1px, transparent 1px),
    linear-gradient(90deg, rgba(212, 168, 67, 0.08) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(circle at center, black 48%, transparent 92%);
}

.font-display {
  font-family: var(--font-display), serif;
  letter-spacing: -0.02em;
}

::selection {
  background: rgba(212, 168, 67, 0.32);
  color: white;
}

a {
  text-decoration: none;
}

/* Aceternity UI — Spotlight 聚光灯扫射动画 */
@keyframes spotlight {
  0% {
    opacity: 0;
    transform: translate(-72%, -62%) scale(0.5);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -40%) scale(1);
  }
}

@utility animate-spotlight {
  animation: spotlight 2s ease 0.75s 1 forwards;
}
